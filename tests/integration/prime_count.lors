func isPrime(n int) bool {
  if n < 2 {
    return false;
  }

  var divisor int = 2;
  for divisor * divisor <= n {
    if (n % divisor) == 0 {
      return false;
    }
    divisor = divisor + 1;
  }

  return true;
}

func countPrimes(limit int) int {
  var value int = 0;
  var total int = 0;

  for value = 0; value <= limit; value = value + 1 {
    if isPrime(value) {
      total = total + 1;
    }
  }

  return total;
}

func entry() int {
  return countPrimes(1000);
}

